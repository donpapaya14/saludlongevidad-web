---
const year = new Date().getFullYear();
const categories = [
  { href: '/categoria/habits',         label: 'Habitos' },
  { href: '/categoria/nutrition',      label: 'Nutricion' },
  { href: '/categoria/exercise',       label: 'Ejercicio' },
  { href: '/categoria/sleep',          label: 'Sueno' },
  { href: '/categoria/aging-science',  label: 'Ciencia del envejecimiento' },
];
const legal = [
  { href: '/aviso-legal',          label: 'Aviso legal' },
  { href: '/politica-privacidad',  label: 'Privacidad' },
  { href: '/politica-cookies',     label: 'Cookies' },
];
const sites = [
  { href: 'https://vida-sana-360.com',      label: 'VidaSana360' },
  { href: 'https://finanzasclara.uk',       label: 'FinanzasClara' },
  { href: 'https://catbrothers.uk',         label: 'CatBrothers' },
  { href: 'https://espaciointeligente.org', label: 'Espacio Inteligente' },
  { href: 'https://cash-cafe.org',          label: 'Cash Cafe' },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <a href="/" class="topbar__brand" style="text-decoration:none">
        <span class="brand-mark" aria-hidden="true">L</span>
        <span class="brand-name">Salud<em>Longevidad</em></span>
      </a>
      <p class="lede" style="font-size:13.5px;margin-top:14px;max-width:340px;color:var(--ink-2)">
        Documental editorial sobre longevidad. Ciencia revisada, habitos blue zones y datos reales — sin promesas magicas.
      </p>
    </div>

    <nav class="site-footer__col" aria-label="Categorias">
      <h4>Categorias</h4>
      <ul>
        {categories.map(c => <li><a href={c.href}>{c.label}</a></li>)}
      </ul>
    </nav>

    <nav class="site-footer__col" aria-label="Conecta">
      <h4>Conecta</h4>
      <ul>
        <li><a href="https://youtube.com/@SaludLongevidad-e3i" target="_blank" rel="noopener">YouTube</a></li>
        <li><a href="/rss.xml">RSS</a></li>
        <li><a href="/sobre-nosotros">Sobre nosotros</a></li>
      </ul>
    </nav>

    <nav class="site-footer__col site-footer__col--sites" aria-label="Nuestras webs">
      <h4>Nuestras webs</h4>
      <ul>
        {sites.map(s => (
          <li><a href={s.href} target="_blank" rel="noopener">{s.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="site-footer__bar">
    <div class="container site-footer__bar-inner">
      <span class="micro">&copy; {year} SaludLongevidad &middot; Contenido informativo, no sustituye consejo medico profesional</span>
      <ul class="site-footer__legal">
        {legal.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    padding: 56px 0 0;
    margin-top: 80px;
    background: linear-gradient(180deg, var(--surface-2) 0%, var(--bg) 100%);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .site-footer__inner {
    display: grid;
    grid-template-columns: 1.6fr repeat(3, 1fr);
    gap: 32px;
    padding-bottom: 44px;
  }
  .site-footer__col h4 {
    color: var(--ink-1);
    font-family: var(--font-mono);
    font-size: 11.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 16px;
  }
  .site-footer__col ul { list-style: none; padding: 0; margin: 0; }
  .site-footer__col li { margin-bottom: 8px; }
  .site-footer__col a {
    color: var(--ink-2);
    font-size: 13.5px;
    text-decoration: none;
    transition: color 0.15s;
  }
  .site-footer__col a:hover { color: var(--accent); }

  .site-footer__bar {
    border-top: 1px solid var(--line);
    padding: 18px 0 28px;
  }
  .site-footer__bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
  }
  .site-footer__legal {
    list-style: none;
    display: flex;
    gap: 18px;
    margin: 0;
    padding: 0;
  }
  .site-footer__legal a {
    color: var(--ink-3);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-decoration: none;
  }
  .site-footer__legal a:hover { color: var(--accent); }

  @media (max-width: 880px) {
    .site-footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
    .site-footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 560px) {
    .site-footer__inner { grid-template-columns: 1fr; }
    .site-footer__bar-inner { flex-direction: column; align-items: flex-start; }
  }
</style>

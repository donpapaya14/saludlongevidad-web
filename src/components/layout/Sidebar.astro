---
import { getCollection } from 'astro:content';
import AdSenseSlot from '../monetization/AdSenseSlot.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const popular = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<aside class="sidebar" aria-label="Barra lateral">
  <div class="sidebar__section sidebar__section--dark">
    <h4 class="sidebar__title">Mas leidos</h4>
    <ul class="sidebar__list">
      {popular.map((post, i) => (
        <li class="sidebar__item">
          <span class="sidebar__num">{String(i + 1).padStart(2, '0')}</span>
          <a href={`/blog/${post.id}`}>{post.data.title}</a>
        </li>
      ))}
    </ul>
  </div>

  <AdSenseSlot position="sidebar" />

  <div class="sidebar__section sidebar__section--yt">
    <h4 class="sidebar__title">YouTube</h4>
    <p class="sidebar__yt-text">Tips de longevidad en 60 segundos. Datos cientificos diarios.</p>
    <a href="https://youtube.com/@SaludLongevidad-e3i" target="_blank" rel="noopener" class="btn btn--outline btn--full">
      Ver canal
    </a>
  </div>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 88px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .sidebar__section {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(14px) saturate(120%);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
  }
  .sidebar__section--dark {
    background: var(--bg-deep);
    border-color: var(--accent-deep);
    color: var(--ink-on-dark);
  }
  .sidebar__title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-1);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--accent);
  }
  .sidebar__section--dark .sidebar__title {
    color: var(--accent-soft);
    border-bottom-color: var(--accent);
  }
  .sidebar__list { list-style: none; padding: 0; margin: 0; }
  .sidebar__item {
    display: flex;
    gap: 0.85rem;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    align-items: baseline;
  }
  .sidebar__item:last-child { border-bottom: none; padding-bottom: 0; }
  .sidebar__num {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 22px;
    color: var(--accent-soft);
    opacity: 0.7;
    flex-shrink: 0;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .sidebar__item a {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-on-dark);
    line-height: 1.4;
    text-decoration: none;
    transition: color 0.15s;
  }
  .sidebar__item a:hover { color: var(--accent-soft); }
  .sidebar__section--yt {
    background: linear-gradient(135deg,
      color-mix(in oklab, var(--accent) 12%, var(--bg-card)),
      var(--bg-card));
    border: 1px solid var(--glass-border);
  }
  .sidebar__yt-text {
    font-size: 14px;
    color: var(--ink-2);
    margin-bottom: 14px;
    line-height: 1.5;
  }
  .btn--full { width: 100%; justify-content: center; }
</style>

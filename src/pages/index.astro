---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/content/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../utils/categories';
import type { Category } from '../utils/categories';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const categories = Object.entries(CATEGORIES) as [Category, (typeof CATEGORIES)[Category]][];
---

<BaseLayout title="SaludLongevidad" description="Longevidad cientifica, biohacking real y habitos blue zones. Datos respaldados por estudios revisados.">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner hero-grid">
      <div class="hero-text">
        <div class="eyebrow">Documental editorial &middot; Longevidad</div>
        <h1 class="display hero__title">
          Vivir mas,<br />
          <em>vivir mejor</em>
        </h1>
        <p class="lede hero__subtitle">
          Longevidad cientifica, biohacking accesible y habitos de las blue zones.
          Datos respaldados por estudios revisados, sin promesas magicas.
        </p>
        <div class="hero__actions">
          <a href="/blog" class="btn-primary">Leer articulos &rarr;</a>
          <a href="#categories" class="btn-ghost">Explorar categorias</a>
        </div>

        <div class="pop-chips" aria-label="Temas populares">
          <span class="pop-chips-label">Temas</span>
          <a href="/categoria/habits" class="pop-chip">Habitos diarios</a>
          <a href="/categoria/nutrition" class="pop-chip">Blue zones</a>
          <a href="/categoria/exercise" class="pop-chip">Movimiento</a>
          <a href="/categoria/sleep" class="pop-chip">Sueno profundo</a>
          <a href="/categoria/aging-science" class="pop-chip">Edad biologica</a>
        </div>
      </div>

      <div class="hero-visual-wrap">
        <figure class="hero__visual">
          <img
            src="https://images.pexels.com/photos/3683074/pexels-photo-3683074.jpeg?auto=compress&cs=tinysrgb&w=900"
            alt="Persona mayor caminando en la naturaleza, simbolo de longevidad activa"
            loading="eager"
            decoding="async"
          />
          <figcaption class="hero__visual-caption">Okinawa &middot; Blue Zone</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <div>
          <div class="eyebrow">Recientes</div>
          <h2 class="section-title">Ultimos articulos</h2>
        </div>
        <a href="/blog" class="section__link">Ver todos &rarr;</a>
      </div>
      <div class="articles-grid">
        {latestPosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            image={post.data.image}
            readingTime={post.data.readingTime}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section id="categories" class="section section--alt">
    <div class="container">
      <div style="text-align:center;margin-bottom:36px">
        <div class="eyebrow" style="justify-content:center">Explorar</div>
        <h2 class="section-title">Por categoria</h2>
      </div>
      <div class="categories-grid">
        {categories.map(([key, cat]) => (
          <a href={`/categoria/${key}`} class={`cat-card cat-card--${key}`}>
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats / Data section (dark) -->
  <section class="section section--dark">
    <div class="container">
      <div style="text-align:center;margin-bottom:24px">
        <div class="eyebrow" style="justify-content:center">Datos</div>
        <h2 class="section-title">La longevidad en numeros</h2>
        <p class="lede" style="max-width:580px;margin:18px auto 0">
          Indicadores reales de las regiones mas longevas del planeta y la ciencia detras de ellos.
        </p>
      </div>
      <div class="stats-grid">
        <div class="stat">
          <div class="stat__value data">+12<span style="font-size:0.6em">a&ntilde;os</span></div>
          <span class="stat__label">Esperanza extra</span>
          <span class="stat__source">Habitos Blue Zone vs media</span>
        </div>
        <div class="stat">
          <div class="stat__value data">7-9<span style="font-size:0.5em">h</span></div>
          <span class="stat__label">Sueno optimo</span>
          <span class="stat__source">Sleep Foundation 2023</span>
        </div>
        <div class="stat">
          <div class="stat__value data">150<span style="font-size:0.5em">min</span></div>
          <span class="stat__label">Ejercicio semana</span>
          <span class="stat__source">OMS minimo recomendado</span>
        </div>
        <div class="stat">
          <div class="stat__value data">95<span style="font-size:0.5em">%</span></div>
          <span class="stat__label">Plant-based</span>
          <span class="stat__source">Dieta longeva (Buettner)</span>
        </div>
      </div>
    </div>
  </section>

  <!-- YouTube CTA -->
  <section class="section">
    <div class="container yt-section">
      <div class="yt-section__text">
        <div class="eyebrow" style="justify-content:center">Video</div>
        <h2 class="section-title">Tambien en YouTube</h2>
        <p class="lede">Shorts diarios con tips de longevidad respaldados por estudios. 60 segundos, datos reales.</p>
        <a href="https://youtube.com/@SaludLongevidad-e3i" target="_blank" rel="noopener" class="btn-primary btn--lg">
          Ver canal &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-visual-wrap {
    width: 100%;
  }
  .yt-section {
    text-align: center;
    max-width: 580px;
    margin: 0 auto;
  }
  .yt-section .lede {
    margin: 14px auto 28px;
  }
  .cat-card--habits         { /* default teal accent applied via global */ }
  .cat-card--nutrition,
  .cat-card--exercise,
  .cat-card--sleep,
  .cat-card--aging-science  { /* uses global cat-card hover accent */ }

  @media (max-width: 600px) {
    .hero { padding: 32px 0 48px; }
    .hero__actions { flex-direction: column; align-items: flex-start; }
    .hero__actions .btn-primary,
    .hero__actions .btn-ghost { width: 100%; justify-content: center; }
  }
</style>
